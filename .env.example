# ============================================================
# ローカル開発では、この .env は基本的に無くても動きます（Keystaticはローカルモード）。
# 本番(Vercel)で /keystatic をオンライン編集したいときだけ GitHub モードの変数が必要です。
# ============================================================

# 公開サイトのURL（canonical / OGP / sitemap 用）
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Keystatic GitHub モード（本番でオンライン編集する場合のみ）----
# "オーナー名/リポジトリ名"。これが設定されると GitHub モードになります。未設定ならローカルモード。
# 例: NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO="yourname/exhaustnote"
NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=""

# 下の4つは、ローカルで一度 /keystatic を開き「Connect to GitHub」を実行すると自動生成されます。
# 生成された値を Vercel の環境変数にコピーしてください（詳しくは README 参照）。
KEYSTATIC_GITHUB_CLIENT_ID=""
KEYSTATIC_GITHUB_CLIENT_SECRET=""
KEYSTATIC_SECRET=""
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=""
